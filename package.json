{
  "name": "openforge-core",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source industrial automation engineering framework for visual workflows, simulation, and vendor-neutral connectivity.",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r build",
    "demo:conveyor": "pnpm --filter @openforge/conveyor-demo simulate",
    "demo:mqtt": "pnpm --filter @openforge/mqtt-signal-integration-demo simulate",
    "dev:web": "pnpm --filter @openforge/web dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "validate:examples": "node scripts/validate-examples.mjs"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
